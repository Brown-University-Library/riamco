# Files to ignore in Git

# Ignore local EAD test files
/ead_files

# Our locally generated HTML finding aids (from the XML+XSLT)
/public/html
/public/info.php

# Ignore bundler config.
/.bundle

# Ignore production generated files
/vendor/bundle
/public/assets

# Ignore the default SQLite databases.
/db/*.sqlite3

# Ignore all logfiles and tempfiles.
/tmp
/log
.byebug_history
.DS_Store

# Ignore our oficial settings and configuration files
.env
refresh.sh
refresh_branch.sh
/http

# Ignore xml folder so it is not accidentally committed
xml/
pdf/

# Ignore scripts
import_all_eads.sh
public/render.php
solr_conf/solr_commands.sh
task.sh
update_solr.sh
scripts/

# Ignore obsolete folder
obsolete/

# Ignore apache tika server
tika/
